function env.Functions:Exit()
    for _, value in pairs(env.Construction) do
        value:Remove()
    end
    AxisConnection:Disconnect()
    CrosshairConnection:Disconnect()
    getgenv().Crosshair = nil
end

function env.Functions:Restart()
